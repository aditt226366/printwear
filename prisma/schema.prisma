generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum LeadStatus {
  NEW       @map("new")
  MESSAGED  @map("messaged")
  REPLIED   @map("replied")
  FAILED    @map("failed")
}

enum LeadTemperature {
  HOT    @map("hot")
  WARM   @map("warm")
  SCRAP  @map("scrap")
}

enum HumanPriority {
  HIGH    @map("high")
  MEDIUM  @map("medium")
  LOW     @map("low")
}

enum OrderStatus {
  COLLECTING_DETAILS  @map("collecting_details")
  READY_FOR_REVIEW    @map("ready_for_review")
  QUOTATION_NEEDED    @map("quotation_needed")
  CONFIRMED           @map("confirmed")
  READY_FOR_DISPATCH  @map("ready_for_dispatch")
  DISPATCHED          @map("dispatched")
  CANCELLED           @map("cancelled")
}

enum MessageDirection {
  INBOUND   @map("inbound")
  OUTBOUND  @map("outbound")
}

enum MessageType {
  TEXT      @map("text")
  TEMPLATE  @map("template")
  IMAGE     @map("image")
  VIDEO     @map("video")
  DOCUMENT  @map("document")
  AUDIO     @map("audio")
}

enum MessageStatus {
  PENDING    @map("pending")
  SENT       @map("sent")
  DELIVERED  @map("delivered")
  READ       @map("read")
  FAILED     @map("failed")
  RECEIVED   @map("received")
}

enum AutomationSendStatus {
  QUEUED     @map("queued")
  SENT       @map("sent")
  FAILED     @map("failed")
  DELIVERED  @map("delivered")
  READ       @map("read")
}

enum BulkJobStatus {
  QUEUED     @map("queued")
  RUNNING    @map("running")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
}

enum CampaignStatus {
  DRAFT      @map("draft")
  SCHEDULED  @map("scheduled")
  RUNNING    @map("running")
  COMPLETED  @map("completed")
  FAILED     @map("failed")
  PAUSED     @map("paused")
  CANCELLED  @map("cancelled")
}

enum CampaignType {
  WHATSAPP_TEMPLATE  @map("whatsapp_template")
}

enum AdDraftStatus {
  DRAFT  @map("draft")
}

enum WorkflowTriggerType {
  KEYWORD   @map("keyword")
  REGEX     @map("regex")
  TEMPLATE  @map("template")
  AD        @map("ad")
}

enum WorkflowRunStatus {
  STARTED   @map("started")
  EXECUTED  @map("executed")
  FAILED    @map("failed")
}

enum KnowledgeSourceType {
  MANUAL   @map("manual")
  WEBSITE  @map("website")
  UPLOAD   @map("upload")
  SEED     @map("seed")
}

enum CompanyStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
}

enum AppUserRole {
  ADMIN
  USER
}

enum AppUserStatus {
  ACTIVE    @map("active")
  INACTIVE  @map("inactive")
}

enum ApiProvider {
  META_WHATSAPP
  META_ADS
  CLAUDE
  GOOGLE_SHEETS
  INTERNAL
}

model Company {
  id             String        @id @default(cuid())
  name           String
  slug           String        @unique
  status         CompanyStatus @default(ACTIVE)
  logoUrl        String?
  whatsappNumber String?
  brandColor     String?
  timezone       String?
  businessType   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  users            AppUser[]
  features         CompanyFeature[]
  apiUsageLogs     ApiUsageLog[]
  billingSnapshots BillingSnapshot[]
  leads            Lead[]
  knowledgeBase    KnowledgeBase[]
  bulkMessageJobs  BulkMessageJob[]
  campaigns        Campaign[]
  adDrafts         AdDraft[]
  aiWorkflows      AiWorkflow[]

  @@index([status])
}

model AppUser {
  id           String        @id @default(cuid())
  companyId    String?
  name         String
  username     String        @unique
  email        String?       @unique
  passwordHash String
  role         AppUserRole
  status       AppUserStatus @default(ACTIVE)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  lastLoginAt  DateTime?

  company      Company?      @relation(fields: [companyId], references: [id], onDelete: SetNull)
  apiUsageLogs ApiUsageLog[]

  @@index([companyId])
  @@index([role])
  @@index([status])
}

model CompanyFeature {
  id          String   @id @default(cuid())
  companyId   String
  featureKey  String
  featureName String
  enabled     Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, featureKey])
  @@index([companyId])
  @@index([featureKey])
}

model ApiUsageLog {
  id            String      @id @default(cuid())
  companyId     String
  userId        String?
  provider      ApiProvider
  endpoint      String
  method        String
  statusCode    Int
  success       Boolean
  requestUnits  Int         @default(1)
  costEstimate  Decimal?
  metadata      Json        @default("{}")
  createdAt     DateTime    @default(now())

  company Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user    AppUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([companyId, createdAt])
  @@index([provider, createdAt])
  @@index([userId])
}

model BillingSnapshot {
  id                  String   @id @default(cuid())
  companyId           String
  periodStart         DateTime
  periodEnd           DateTime
  whatsappApiCalls    Int      @default(0)
  metaAdsApiCalls     Int      @default(0)
  claudeApiCalls      Int      @default(0)
  googleSheetsApiCalls Int     @default(0)
  totalApiCalls       Int      @default(0)
  estimatedCost       Decimal  @default(0)
  metadata            Json     @default("{}")
  createdAt           DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId, periodStart, periodEnd])
}

model Lead {
  id                   String           @id @default(cuid())
  companyId            String
  name                 String
  phone                String
  status               LeadStatus       @default(NEW)
  source               String           @default("google_sheets")
  messageCount         Int              @default(0)
  leadTemperature      LeadTemperature  @default(SCRAP)
  temperatureReason    String           @default("0-1 messages")
  humanTakeoverRequired Boolean         @default(false)
  humanPriority        HumanPriority?
  humanReason          String?
  humanResolvedAt      DateTime?
  googleSheetRowNumber Int?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  messages              Message[]
  sendLogs              SendLog[]
  orderSummary          OrderSummary?
  bulkRecipients        BulkMessageRecipient[]
  campaignRecipients    CampaignRecipient[]
  workflowExecutionLogs WorkflowExecutionLog[]
  company               Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@unique([companyId, phone])
  @@unique([companyId, googleSheetRowNumber])
  @@index([companyId])
  @@index([status])
  @@index([leadTemperature])
  @@index([humanTakeoverRequired, humanResolvedAt])
  @@index([source])
}

model Message {
  id                String            @id @default(cuid())
  leadId            String
  whatsappMessageId String?           @unique
  direction         MessageDirection
  type              MessageType
  content           String
  status            MessageStatus
  rawPayload        Json?
  createdAt         DateTime          @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId, createdAt])
  @@index([status])
}

model KnowledgeBase {
  id          String              @id @default(cuid())
  companyId   String
  title       String
  content     String
  category    String
  sourceType  KnowledgeSourceType @default(MANUAL)
  sourceUrl   String?
  sourceName  String?
  sourceKey   String?
  chunkIndex  Int                 @default(0)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([category])
  @@index([sourceType])
  @@index([sourceKey])
}

model SendLog {
  id           String   @id @default(cuid())
  leadId       String?
  action       String
  status       String
  errorMessage String?
  createdAt    DateTime @default(now())

  lead Lead? @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([action, status])
}

model BulkMessageJob {
  id               String        @id @default(cuid())
  companyId        String
  name             String
  templateName     String
  templateLanguage String        @default("en_US")
  status           BulkJobStatus @default(QUEUED)
  totalCount       Int           @default(0)
  sentCount        Int           @default(0)
  failedCount      Int           @default(0)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  recipients BulkMessageRecipient[]
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status, createdAt])
}

model BulkMessageRecipient {
  id                String               @id @default(cuid())
  bulkMessageJobId  String
  leadId            String
  phone             String
  status            AutomationSendStatus @default(QUEUED)
  whatsappMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  bulkMessageJob BulkMessageJob @relation(fields: [bulkMessageJobId], references: [id], onDelete: Cascade)
  lead           Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([bulkMessageJobId, leadId])
  @@index([status])
  @@index([whatsappMessageId])
}

model Campaign {
  id               String         @id @default(cuid())
  companyId        String
  name             String
  type             CampaignType   @default(WHATSAPP_TEMPLATE)
  audience         Json
  templateName     String
  templateLanguage String         @default("en_US")
  messagePreview   String?
  scheduledAt      DateTime?
  status           CampaignStatus @default(DRAFT)
  totalCount       Int            @default(0)
  sentCount        Int            @default(0)
  failedCount      Int            @default(0)
  repliesCount     Int            @default(0)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt

  recipients CampaignRecipient[]
  company    Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([status, scheduledAt])
  @@index([createdAt])
}

model CampaignRecipient {
  id                String               @id @default(cuid())
  campaignId        String
  leadId            String
  phone             String
  status            AutomationSendStatus @default(QUEUED)
  whatsappMessageId String?
  errorMessage      String?
  sentAt            DateTime?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead     Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([campaignId, leadId])
  @@index([status])
  @@index([whatsappMessageId])
}

model AdDraft {
  id                         String        @id @default(cuid())
  companyId                  String
  name                       String
  objective                  String
  audience                   String
  headline                   String
  bodyText                   String
  cta                        String
  destinationWhatsAppNumber  String
  templatePreview            String
  status                     AdDraftStatus @default(DRAFT)
  createdAt                  DateTime      @default(now())
  updatedAt                  DateTime      @updatedAt

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([createdAt])
}

model AiWorkflow {
  id           String              @id @default(cuid())
  companyId    String
  name         String
  isActive     Boolean             @default(false)
  triggerType  WorkflowTriggerType
  triggerValue String
  definition   Json
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  executionLogs WorkflowExecutionLog[]
  company       Company @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isActive, triggerType])
}

model WorkflowExecutionLog {
  id           String            @id @default(cuid())
  workflowId   String
  leadId       String?
  status       WorkflowRunStatus
  stepKey      String?
  errorMessage String?
  createdAt    DateTime          @default(now())

  workflow AiWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  lead     Lead?      @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([workflowId, createdAt])
  @@index([leadId])
}

model FeatureFlag {
  key       String   @id
  label     String
  enabled   Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderSummary {
  id               String      @id @default(cuid())
  leadId           String      @unique
  productType      String?
  quantity         Int?
  size             String?
  color            String?
  gsm              String?
  customization    String?
  deliveryLocation String?
  notes            String?
  status           OrderStatus @default(COLLECTING_DETAILS)
  confidenceScore  Float       @default(0)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([updatedAt])
}
